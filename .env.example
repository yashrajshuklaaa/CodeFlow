# Local Docker / self-hosted
MONGODB_URI=mongodb://127.0.0.1:27017/codeflow
REDIS_URL=redis://127.0.0.1:6379

# Production (Render + Atlas + Upstash)
# NODE_ENV=production
# PORT=3000
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/codeflow?retryWrites=true&w=majority
# REDIS_URL=rediss://default:PASSWORD@xxxxx.upstash.io:6379
